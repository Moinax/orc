{
  "openapi": "3.0.3",
  "info": {
    "title": "Documents API",
    "version": "1.0.0"
  },
  "paths": {
    "/contracts/{contractId}": {
      "get": {
        "tags": ["contract"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "contractId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Contract" }
              }
            }
          }
        }
      }
    },
    "/contracts/{contractId}/documents": {
      "get": {
        "tags": ["contract"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "contractId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "documentId": { "type": "integer" },
                          "label": { "type": "string" },
                          "reportDate": { "type": "string", "nullable": true }
                        },
                        "required": ["documentId", "label", "reportDate"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["data"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/contracts/{contractId}/documents/{documentId}": {
      "get": {
        "tags": ["contract"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "contractId",
            "required": true
          },
          {
            "schema": { "type": "integer" },
            "in": "path",
            "name": "documentId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    },
    "/reports/{reportId}/file": {
      "get": {
        "tags": ["report"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "reportId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Contract": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reference": { "type": "string" }
        },
        "required": ["id", "reference"],
        "additionalProperties": false
      }
    }
  }
}
